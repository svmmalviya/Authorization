@model string
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Login";
  var count= HttpContextAccessor.HttpContext.Session.GetInt32("requestcount");
}

<h2>@ViewData["Title"]</h2>

<form id="loginForm" method="post">   
    <div class="form-group">
        <button type="submit" class="btn btn-primary">Update Count <p id="pcount"></p> </button>
    </div>

</form>
<script>


     document.getElementById("loginForm").addEventListener("submit", function (event) {
        event.preventDefault();

        // Get the token from localStorage
    var token = localStorage.getItem('authToken');

    // Send the token in the Authorization header
    fetch('/Auth/GetData', {
        method: 'GET',
        headers: {
            'Authorization': 'Bearer ' + token
        }
    })
    .then(response => response.json())
    .then(data => {
       document.getElementById('pcount').innerText=data;
        console.log('Data from protected endpoint:', data);
    })
    .catch(error => {
        console.error('Error:', error);
    });
     });

</script>
